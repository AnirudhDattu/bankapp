<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_view_credit_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardPreventCornerOverlap="false"
    app:strokeWidth="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/premium_card_gradient"
        android:padding="24dp">

        <!-- Bank Name / Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IZBANK"
            android:textColor="@color/pure_white"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.2"
            android:alpha="0.9"/>

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/icon_bank"
            app:tint="@color/premium_card_accent"
            android:alpha="0.8"/>

        <!-- Chip Simulation -->
        <View
            android:id="@+id/card_chip"
            android:layout_width="45dp"
            android:layout_height="35dp"
            android:layout_marginTop="45dp"
            android:background="@drawable/edittext_border"
            android:backgroundTint="#FFD700"
            android:alpha="0.7"/>

        <!-- Card Number -->
        <TextView
            android:id="@+id/text_view_credit_card_no"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/card_chip"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:text="4532 7890 1234 5678"
            android:textColor="@color/pure_white"
            android:textSize="16sp"
            android:letterSpacing="0.05"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:gravity="bottom"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CARD HOLDER"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true"/>
                <TextView
                    android:id="@+id/text_view_card_holder_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="VALUED CUSTOMER"
                    android:textColor="@color/pure_white"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AVAILABLE LIMIT"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true"/>
                <TextView
                    android:id="@+id/text_view_credit_card_limit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="₹10,000"
                    android:textColor="@color/premium_card_accent"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
