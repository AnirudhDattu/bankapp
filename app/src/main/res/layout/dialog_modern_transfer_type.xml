<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/apple_card_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="Transfer Type"
        android:textColor="@color/apple_text_primary"
        android:textSize="20sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_transfer_internal"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="20dp"
        android:text="Between My Accounts"
        android:textAllCaps="false"
        android:textColor="@color/apple_text_primary"
        app:cornerRadius="16dp"
        app:strokeColor="@color/apple_grey_light" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_transfer_external"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="12dp"
        android:text="To Another Person"
        android:textAllCaps="false"
        android:textColor="@color/apple_text_primary"
        app:cornerRadius="16dp"
        app:strokeColor="@color/apple_grey_light" />

</LinearLayout>