<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/apple_background"
    android:padding="24dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            app:tint="@color/apple_text_primary" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Send Money"
            android:fontFamily="sans-serif-black"
            android:textSize="20sp"
            android:textColor="@color/apple_text_primary" />
    </RelativeLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/apple_grey_light"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:id="@+id/txt_recipient_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recipient Name"
                android:textSize="22sp"
                android:fontFamily="sans-serif-bold"
                android:textColor="@color/apple_text_primary" />

            <TextView
                android:id="@+id/txt_recipient_upi_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="recipient@upi"
                android:textSize="14sp"
                android:textColor="@color/apple_text_secondary"
                android:layout_marginTop="4dp" />

            <EditText
                android:id="@+id/edt_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@null"
                android:hint="₹ 0"
                android:inputType="numberDecimal"
                android:textSize="48sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/apple_text_primary"
                android:gravity="center" />

            <EditText
                android:id="@+id/edt_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/apple_edittext_bg"
                android:hint="Add a note (optional)"
                android:padding="12dp"
                android:textSize="14sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Paying from"
        android:fontFamily="sans-serif-bold"
        android:textSize="16sp"
        android:textColor="@color/apple_text_primary"
        android:layout_marginTop="32dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_selected_bank"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/apple_grey_light"
        app:strokeWidth="1dp"
        android:clickable="true"
        android:focusable="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/icon_bank"
                app:tint="@color/apple_blue" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txt_selected_bank_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IzBank - XXXX"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/apple_text_primary" />
                <TextView
                    android:id="@+id/txt_selected_bank_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Balance: ₹ 0.00"
                    android:textColor="@color/apple_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/apple_text_secondary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btn_pay_now"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Pay Now"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:fontFamily="sans-serif-bold"
        android:backgroundTint="@color/apple_blue"
        app:cornerRadius="28dp" />

</LinearLayout>