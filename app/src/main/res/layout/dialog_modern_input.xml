<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/apple_card_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="Title"
        android:textColor="@color/apple_text_primary"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/dialog_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Message"
        android:textColor="@color/apple_text_secondary"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/dialog_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/apple_edittext_bg"
        android:fontFamily="sans-serif-medium"
        android:hint="0"
        android:inputType="number"
        android:padding="16dp"
        android:textColor="@color/apple_text_primary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dialog_btn_action"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Action"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="sans-serif-bold"
        app:cornerRadius="16dp"
        app:backgroundTint="@color/apple_blue"
        app:elevation="0dp" />

</LinearLayout>